{
  "name": "bingobanko",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "engines": {
    "node": "^24.15.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "pnpm type-check && vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "deploy:worker": "pnpm build && wrangler deploy --config wrangler.jsonc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/vue": "^1.0.5",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "overrides": {
      "glob": "latest",
      "minimatch": "^10.2.1",
      "flatted": "^3.4.2"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
