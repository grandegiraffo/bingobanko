{
  "name": "bingobanko",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "engines": {
    "node": "^24.15.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm type-check && vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "deploy:worker": "pnpm build && wrangler deploy --config wrangler.jsonc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/vue": "^1.0.5",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.2",
    "wrangler": "^4.95.0"
  }
}
